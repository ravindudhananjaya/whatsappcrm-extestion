{
"update_url": "https://clients2.google.com/service/update2/crx",

  "name": "__MSG_extName__",
  "short_name": "__MSG_extShortName__",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "version": "2.3.490.1190",
  "manifest_version": 3,
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "static/js/vendors.js",
        "static/js/content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "static/js/background.js"
  },
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  "icons": {
    "16": "static/images/the_chat_quotient_logo_16.png",
    "48": "static/images/the_chat_quotient_logo_48.png",
    "128": "static/images/the_chat_quotient_logo_128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "static/js/vendors.js",
        "static/js/main.js",
        "static/js/wpp.js",
        "static/js/injector.js",
        "static/images/the_chat_quotient_logo_16.png",
        "static/images/the_chat_quotient_logo_48.png",
        "static/images/the_chat_quotient_logo_128.png",
        "static/images/inactive/the_chat_quotient_logo_16.png",
        "static/images/inactive/the_chat_quotient_logo_48.png",
        "static/images/inactive/the_chat_quotient_logo_128.png",
        "reminder-window.html",
        "reminder-window.js",
        "_locales/*/messages.json"
      ],
      "matches": [
        "https://web.whatsapp.com/*"
      ]
    }
  ]
}
